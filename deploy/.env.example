STRATEGYOS_WORKSPACE_ROOT=/app/workspace
STRATEGYOS_OUTPUT_ROOT=/app/workspace/outputs
STRATEGYOS_SOURCE_DATASET=/app/workspace/source_dataset
STRATEGYOS_AGENT_INPUT_DIR=/app/workspace/agent_input
STRATEGYOS_EVALUATION_DIR=/app/workspace/evaluation
STRATEGYOS_RUN_DIR=/app/workspace/outputs/latest
STRATEGYOS_TENANT_SLUG=local-poc
STRATEGYOS_TENANT_NAME=StrategyOS Local POC
STRATEGYOS_ENVIRONMENT_LABEL=Local development
STRATEGYOS_SOURCE_SYSTEM_NAME=Synthetic Finance Dataset
STRATEGYOS_OCR_ENGINE=tesseract
STRATEGYOS_RUNTIME_DEP_CA_CERTIFICATES_VERSION=20250419
STRATEGYOS_RUNTIME_DEP_CURL_VERSION=8.14.1-2+deb13u3
STRATEGYOS_RUNTIME_DEP_POPPLER_UTILS_VERSION=25.03.0-5+deb13u3
STRATEGYOS_RUNTIME_DEP_TESSERACT_VERSION=5.5.0-1+b1
STRATEGYOS_RUNTIME_DEP_TESSERACT_ENG_VERSION=1:4.1.0-2
STRATEGYOS_RUN_POLICY=sovereign
STRATEGYOS_APPROVED_EXTERNAL_MODES=
STRATEGYOS_MODEL_PROVIDER_ENABLED=false
STRATEGYOS_LLM_CHAT_ENABLED=false
STRATEGYOS_LLM_PROVIDER=deepseek
STRATEGYOS_LLM_BASE_URL=https://api.deepseek.com
STRATEGYOS_LLM_MODEL=deepseek-v4-pro
STRATEGYOS_LLM_TIMEOUT_SECONDS=30
STRATEGYOS_BATCH_APIS_ENABLED=false
STRATEGYOS_HOSTED_OCR_VISION_ENABLED=false
STRATEGYOS_AUTH_MODE=identity_provider
STRATEGYOS_API_AUTH_ENABLED=true
STRATEGYOS_DEMO_ROLE_LOGIN_ENABLED=false
STRATEGYOS_IDP_ENABLED=true
STRATEGYOS_IDP_HTTP_PORT=8089
STRATEGYOS_IDP_ISSUER=http://localhost:8089
STRATEGYOS_IDP_TOKEN_URL=http://strategyos-idp:9000/oauth/token
STRATEGYOS_IDP_INTROSPECTION_URL=http://strategyos-idp:9000/oauth/introspect
STRATEGYOS_IDP_CLIENT_ID=strategyos-local-client
STRATEGYOS_IDP_OPERATOR_USERNAME=operator.local
STRATEGYOS_IDP_REVIEWER_USERNAME=reviewer.local
# Optional temporary browser-login test users, formatted as username=password pairs.
# Role is inferred from the username prefix before the first dot; tenant roles may use hyphens.
# Example: operator.tester=change-me,reviewer.tester=change-me,executive.tester=change-me,tenant-admin.tester=change-me
STRATEGYOS_IDP_TEST_USERS=
STRATEGYOS_IDP_TOKEN_TTL_SECONDS=3600
STRATEGYOS_TRUST_PROXY_AUTH=false
STRATEGYOS_OPERATOR_EMAILS=
STRATEGYOS_REVIEWER_EMAILS=
OAUTH2_PROXY_PROVIDER=oidc
OAUTH2_PROXY_OIDC_ISSUER_URL=
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_REDIRECT_URL=
OAUTH2_PROXY_EMAIL_DOMAINS=*
OAUTH2_PROXY_SCOPE=openid email profile
OAUTH2_PROXY_COOKIE_SECURE=false
STRATEGYOS_PUBLIC_HEALTH_ENABLED=false
STRATEGYOS_REQUIRE_HUMAN_REVIEW=true
STRATEGYOS_SYNC_ARTIFACTS=true
STRATEGYOS_SYNC_SOURCE_FILES=false
STRATEGYOS_RUN_EXECUTION_MODE=sync
STRATEGYOS_RUNTIME_BACKEND=langgraph
STRATEGYOS_SITE_ADDRESS=:80
STRATEGYOS_HTTP_PORT=80
STRATEGYOS_HTTPS_PORT=443

POSTGRES_DB=strategyos
POSTGRES_USER=strategyos
REDIS_URL=redis://redis:6379/0
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
QDRANT_URL=http://qdrant:6333

# Optional Hatchet worker mode. Enable with:
# docker compose --profile hatchet -f deploy/docker-compose.yml ...
HATCHET_CLIENT_TLS_STRATEGY=none
HATCHET_CLIENT_HOST_PORT=hatchet-lite:7077
HATCHET_CLIENT_SERVER_URL=http://hatchet-lite:8888
STRATEGYOS_HATCHET_WORKER_NAME=strategyos-worker
STRATEGYOS_HATCHET_WORKER_SLOTS=1
STRATEGYOS_HATCHET_DASHBOARD_URL=http://localhost:8888
HATCHET_POSTGRES_DB=hatchet
HATCHET_POSTGRES_USER=hatchet
HATCHET_DASHBOARD_PORT=8888
HATCHET_GRPC_PORT=7077

STRATEGYOS_OBJECT_ENDPOINT=http://minio:9000
STRATEGYOS_OBJECT_BUCKET=strategyos
STRATEGYOS_OBJECT_ACCESS_KEY_ID=strategyos
STRATEGYOS_OBJECT_REGION=us-east-1
STRATEGYOS_OBJECT_PREFIX=strategyos
STRATEGYOS_OBJECT_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=strategyos
